rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função para verificar se o usuário está na whitelist
    function isAuthorized() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/allowed_emails/$(request.auth.token.email.lower()));
    }

    // Regra Global: Apenas usuários na whitelist podem ler ou gravar
    match /{document=**} {
      // Exceção: O próprio processo de login precisa verificar se o e-mail existe na lista
      // Mas permitimos apenas 'get' no documento específico do e-mail para checagem inicial
      match /allowed_emails/{email} {
        allow get: if request.auth != null;
        allow list, write: if isAuthorized();
      }
      
      // Todas as outras coleções exigem autorização completa
      match /{allOther=**} {
        allow read, write: if isAuthorized();
      }
    }
  }
}